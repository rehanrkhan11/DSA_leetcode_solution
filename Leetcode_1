Leetcode_1 : Two Sum

class Solution {
    public int[] twoSum(int[] nums, int target) {
        HashMap<Integer,Integer> mp=new HashMap<>();
        int sum=0;

        for(int i=0;i<nums.length;i++){
            int other=target-nums[i];


            if(mp.containsKey(other)){
                return new int[]{i,mp.get(other)};
            }
            mp.put(nums[i],i);

        }
        return new int[]{};

    }
}
