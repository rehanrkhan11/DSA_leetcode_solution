9. Palindrome Number

class Solution {
    public boolean isPalindrome(int x) {
        if(x<0){
            return false;
        }
        int org=x;
        int sum=0;
        while(org!=0){
            int digit=org%10;
            sum=sum*10+digit;
            org=org/10;

        }

        return sum==x;
        
    }
}
