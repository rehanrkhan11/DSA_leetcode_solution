Leetcode 53::Maximum Subarray

class Solution {
    public int maxSubArray(int[] nums) {
        int smax=nums[0];
        int max=smax;
        for(int i=1;i<nums.length;i++){
            smax=Math.max(nums[i],nums[i]+smax);
            max=Math.max(max,smax);

        }
        return max;
        
    }
}
