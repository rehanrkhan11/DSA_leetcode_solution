 LeetCode 53. Maximum Subarray

class Solution {
    public int maxSubArray(int[] nums) {
        int max=nums[0];
        int s_max=max;
        int sum=0;

        for(int i=1;i<nums.length;i++){
           // sum+=nums[i]+max;

            max=Math.max(nums[i],nums[i]+max);
            s_max=Math.max(s_max,max);

        }
        return s_max;
        
    }
}
