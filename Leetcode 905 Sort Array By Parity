class Solution {
    public int[] sortArrayByParity(int[] nums) {
        int res[]=new int[nums.length];
        int s=0;
        int e=nums.length-1;
        for(int i=0;i<nums.length;i++){
            if(nums[i]%2==0){
                res[s]=nums[i];
                s++;


            }else{
                res[e]=nums[i];
                e--;
            }
        }
        return res;
        
    }
}
