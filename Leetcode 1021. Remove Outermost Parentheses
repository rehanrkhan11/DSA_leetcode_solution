
class Solution {
    public String removeOuterParentheses(String s) {
        StringBuilder sb=new StringBuilder();
        int sum=1;
        for(int i=0;i<s.length();i++){
            char ch=s.charAt(i);

            if(ch=='('){
                sum++;
                if(sum>2){
                    sb.append(ch);
                }


            }else{
                if(sum>2){
                    sb.append(ch);
                   // sum--;
                }
                sum--;
            }

        }
        return sb.toString();
        
    }
}
