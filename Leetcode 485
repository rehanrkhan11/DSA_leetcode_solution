Leetcode 485 : Max Consecutive Ones

class Solution {
    public int findMaxConsecutiveOnes(int[] nums) {
        int count=0;
        int max=count;
        for(int i=0;i<nums.length;i++){
            if(nums[i]!=1){
                  
                count=0;
              
            }else{
                count++;

            }
            max=Math.max(max,count);
            
            

        }
        return max;
    }
}
