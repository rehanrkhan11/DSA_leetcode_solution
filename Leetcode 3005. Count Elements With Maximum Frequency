class Solution {
    public int maxFrequencyElements(int[] nums) {
        HashMap<Integer,Integer> mp=new HashMap<>();
        int max=0;
        int count=0;

        for(int i=0;i<nums.length;i++){
            mp.put(nums[i],mp.getOrDefault(nums[i],0)+1);
        }

        for(Integer key:mp.keySet()){
            if(mp.get(key)>max){
                max=mp.get(key);

            }
        }

        for(Integer key:mp.keySet()){
            if(mp.get(key)==max){
                count+=mp.get(key);

            }
        }
        return count;

        

        
    }
}
