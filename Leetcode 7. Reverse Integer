
class Solution {
    public int reverse(int x) {
        int sum=0;
         int temp=x;

        while(temp!=0){
           
            int digit=temp%10;
            if(sum>Integer.MAX_VALUE/10 || sum<Integer.MIN_VALUE/10){
                return 0;
            }

            
            sum=sum*10+digit;
            
            temp=temp/10;

        }

       

        return sum;
        
    }
}
