```Leetcode 258. Add Digits```

class Solution {
    public int addDigits(int num) {

        while (num >= 10) { // keep going while num has more than 1 digit
            int sum = 0;

            while (num != 0) {
                sum += num % 10;
                num /= 10;
            }

            num = sum;
        }

        return num;
    }
}
