Leetcode 121. Best Time to Buy and Sell Stock

class Solution {
    public int maxProfit(int[] prices) {
        int max=prices[0];
        int smax=0;
        

        for(int i=1;i<prices.length;i++){
            max=Math.min(max,prices[i]);
            
            smax=Math.max(smax,prices[i]-max);

        }
        return smax;
        
    }
}
