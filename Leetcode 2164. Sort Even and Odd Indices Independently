class Solution {
    public int[] sortEvenOdd(int[] nums) {

        int[] even = new int[(nums.length + 1) / 2];
        int[] odd = new int[nums.length / 2];
        int[] res = new int[nums.length];

        int e = 0, o = 0;

        for (int i = 0; i < nums.length; i++) {
            if (i % 2 == 0){
                even[e++] = nums[i];

            }
                
            else{
                odd[o++] = nums[i];

            }
                
        }

        Arrays.sort(even);
        Arrays.sort(odd);

        int evenIndex = 0;
        int oddIndex = odd.length - 1;

        for (int i = 0; i < nums.length; i++) {
            if (i % 2 == 0){
                res[i] = even[evenIndex];
                evenIndex++;
            }
            else{
                res[i] = odd[oddIndex];
                oddIndex--;
            }
        }

        return res;
    }
}
